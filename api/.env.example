# Copy this file to .env for local development.
# When running via Docker Compose these are set in docker-compose.yml.

# MongoDB connection string
# Local dev  → mongodb://localhost:27017/timekeeper
# Docker     → mongodb://mongodb:27017/timekeeper   (service name from compose)
MONGODB_URI=mongodb://localhost:27017/timekeeper

# JWT signing secret — change this in any real deployment
JWT_SECRET=timekeeper-dev-secret-change-in-prod

# API port
PORT=3000
